APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tripcast
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_0900_ai_ci

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# MailerSend API token from the *tripcast* MailerSend account (not another
# project's — a copied cruisin4parts key produced confusing 422s once).
# Production sends require MAIL_MAILER=mailersend.
MAILERSEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Restricted server-side key: Geocoding API + Places API (New) enabled
# (destination autocomplete + place-id resolution ride the same key).
GOOGLE_GEOCODING_KEY=

WEATHERAPI_KEY=

# AI Narrator (AD-17, Story 4.2)
ANTHROPIC_API_KEY=

# Physical postal address rendered in every email footer (CAN-SPAM).
# Required on the production env checklist (Story 9.6).
TRIPCAST_POSTAL_ADDRESS=

# Daily digest send hour on the America/New_York clock (0–23; default 7 = 7am ET).
# TRIPCAST_SEND_HOUR=7

# Daily-run dead-man's-switch (AD-14): the send command GETs {url} on a
# healthy run and {url}/fail on an unhealthy one (e.g. a healthchecks.io
# check URL). Unset = silent no-op (local/dev).
TRIPCAST_HEARTBEAT_URL=
# TRIPCAST_HEARTBEAT_TIMEOUT=5

# One-click unsubscribe mailto arm; defaults to MAIL_FROM_ADDRESS when unset.
# TRIPCAST_UNSUBSCRIBE_MAILTO=

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX). Empty = no gtag.js tag
# rendered, so local/dev traffic never reaches Analytics. Set in prod (+ staging
# if you want to measure it) to enable page-view and key-event tracking.
GOOGLE_ANALYTICS_ID=

# ---- Production go-live checklist (Story 9.6 / FR-27) ----
# Values that MUST be real in production:
#   APP_KEY  (php artisan key:generate — session/CSRF/crypto root key)
#   APP_ENV=production, APP_DEBUG=false, APP_URL=https://tripcast.fyi
#   MAIL_MAILER=mailersend, MAIL_FROM_ADDRESS=hello@tripcast.fyi
#   QUEUE_CONNECTION=redis, CACHE_STORE=redis
#   REDIS_CLIENT=predis (or phpredis if the server has the extension —
#     the dev default here is predis; pick deliberately on the server)
#   GOOGLE_GEOCODING_KEY  (restricted key: Geocoding API + Places API (New))
#   WEATHERAPI_KEY        (plan must serve days=8 — verified 2026-07-01)
#   MAILERSEND_API_KEY    (tripcast account; List-Unsubscribe gate #MS42235
#     must be resolved before daily digests send — Story 9.6 Task 5)
#   TRIPCAST_POSTAL_ADDRESS, TRIPCAST_HEARTBEAT_URL
#   ANTHROPIC_API_KEY optional — the narrator ships deterministic.
#   GOOGLE_ANALYTICS_ID optional — set to turn on GA4 traffic + key-event tracking.
